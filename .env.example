# Alpaca API
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# LLM APIs (optional, for agent trading)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here

# CommonStack unified gateway (one key for OpenAI/Google/xAI/DeepSeek/Qwen/Anthropic).
# When set, leaderboard LLM models route through CommonStack instead of native Anthropic.
COMMONSTACK_API_KEY=your_commonstack_key_here
COMMONSTACK_BASE_URL=https://api.commonstack.ai

# Discord bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here
# One or more guild (server) ids to sync slash commands to (comma-separated).
DISCORD_GUILD_ID=123456789012345678,987654321098765432
# Optional channel allowlist (comma-separated). When set, the bot only responds
# to commands in these channels; leave unset to allow any channel.
DISCORD_CHANNEL_ID=234567890123456789
# Base URL of the backend API the bot calls (defaults to http://localhost:8000).
ATL_API_BASE=http://localhost:8000

# Database
DATABASE_PATH=dashboard/storage/data/backtest.db

# API Configuration
PORT=8000
DEBUG=false
PYTHONUNBUFFERED=true
